# jsdom's html-encoding-sniffer (via @exodus/bytes, ESM-only) needs Node's stable require(esm)
# support — absent on Node 21 and earlier. engine-strict turns the `engines` mismatch in
# package.json into a hard install failure instead of a silent warning followed by a cryptic
# ERR_REQUIRE_ESM crash the first time `npm run test`/`check` boots the jsdom environment.
engine-strict=true
