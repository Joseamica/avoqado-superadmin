# ============================================================
# avoqado-superadmin — variables de entorno
# ============================================================
# Copia este archivo a .env:
#     cp .env.example .env
#
# Todas las variables VITE_* son PÚBLICAS (terminan en el bundle
# del navegador). NO pongas secretos aquí.
# ============================================================

# Backend de avoqado-server (dev local)
VITE_API_URL=http://localhost:3000/api/v1

# Staging:
# VITE_API_URL=https://avoqado-server-staging.fly.dev/api/v1
# Producción:
# VITE_API_URL=https://api.avoqado.io/api/v1

# Google OAuth (mismo client ID del web-dashboard — login por Google).
# Solo se usa si habilitas el botón "Continuar con Google" en el LoginPage.
VITE_GOOGLE_CLIENT_ID=
